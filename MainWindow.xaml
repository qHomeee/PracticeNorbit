<Window x:Class="AutoPrint.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoPrint" Height="500" Width="650"
        Closing="Window_Closing">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <Label Content="Выберите принтер:"/>
            <ComboBox Name="PrinterBox" 
                      SelectionChanged="PrinterBox_SelectionChanged"
                      HorizontalAlignment="Left" Width="300"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <Label Content="Папки для мониторинга:"/>
            <ListBox Name="FoldersList" Height="120" Margin="0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <TextBox Name="NewFolderBox" Width="250" Margin="0,0,5,0"/>
                <Button Name="BrowseFolderButton" Content="Обзор..." Click="BrowseFolder_Click" Margin="0,0,5,0"/>
                <Button Name="AddFolderButton" Content="Добавить" Click="AddFolder_Click" Margin="0,0,5,0"/>
                <Button Name="RemoveFolderButton" Content="Удалить" Click="RemoveFolder_Click"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Left">
            <Button Name="StartButton" Content="Старт" Width="100" Height="30" Margin="0,0,10,0"
                    Click="StartButton_Click" FontWeight="Bold"/>
            <Button Name="StopButton" Content="Стоп" Width="100" Height="30" Margin="0,0,10,0"
                    Click="StopButton_Click" FontWeight="Bold" IsEnabled="False"/>
            <TextBlock Name="StatusText" VerticalAlignment="Center" FontWeight="SemiBold" Margin="10,0,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,2">
            <Label Content="Лог:"/>
        </StackPanel>

        <ListBox Grid.Row="4" Name="LogBox" Margin="0,0,0,5"/>
    </Grid>
</Window>