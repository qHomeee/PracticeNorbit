<Window x:Class="AutoPrint.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoPrint" Height="400" Width="600">

	<Grid Margin="10">

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- Папка -->
		<StackPanel Orientation="Horizontal" Margin="0,0,0,10">
			<TextBox Width="350" Name="FolderBox" IsReadOnly="True"/>
			<Button Width="120" Margin="10,0,0,0" Click="SelectFolder_Click">
				Папка
			</Button>
		</StackPanel>

		<!-- Принтер -->
		<ComboBox Grid.Row="1" Name="PrinterBox" Height="25" Margin="0,0,0,10"/>

		<!-- Кнопки -->
		<StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
			<Button Width="100" Click="Start_Click">Start</Button>
			<Button Width="100" Margin="10,0,0,0" Click="Stop_Click">Stop</Button>
		</StackPanel>

		<!-- Лог -->
		<ListBox Grid.Row="3" Name="LogBox"/>

	</Grid>
</Window>